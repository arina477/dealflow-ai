# Twenty Self-Hosting Environment Template
# Copy to .env and fill in values. NEVER commit secrets to version control.
# All secrets are orchestrator-generated or account-issued (see below).

# === Core Configuration ===
NODE_ENV=production
TWENTY_VERSION=0.32.0

# === Generated Secrets (orchestrator: openssl rand -base64 32) ===
APP_SECRET=
ENCRYPTION_KEY=

# === PostgreSQL ===
POSTGRES_USER=twenty_user
POSTGRES_PASSWORD=
POSTGRES_DB=twenty_db

# === URLs (must be HTTPS for production) ===
SERVER_URL=https://crm.example.com
FRONT_BASE_URL=https://crm.example.com

# === Bootstrap Flag (set to true ONLY during initial provisioning spike) ===
IS_SIGN_UP_ENABLED=false

# === Object Storage (S3-Compatible) ===
STORAGE_TYPE=s3
AWS_S3_REGION=auto
AWS_S3_BUCKET=dealflow-twenty-uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# === Notes ===
# - APP_SECRET & ENCRYPTION_KEY: Generate with `openssl rand -base64 32`
# - POSTGRES_PASSWORD: Generate with `openssl rand -base64 32`
# - AWS_*: Account-issued (Cloudflare R2) or orchestrator-generated (MinIO)
# - SERVER_URL & FRONT_BASE_URL: Must be HTTPS; no trailing slashes
# - IS_SIGN_UP_ENABLED: Set to "true" for bootstrap spike ONLY; revert to "false" after
