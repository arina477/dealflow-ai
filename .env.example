# .env.example — placeholders for project env vars.
# Populated at v6b (onboarding) from architecture/{security,sdks,databases,services,devops}.md.
# After onboarding, B-0 Action 3 appends new placeholders per wave.
#
# DO NOT commit .env (gitignored). Generate secrets per always-on rule #6:
#   openssl rand -base64 32

# ── Database — Postgres on Railway (architecture/databases.md) ──
DATABASE_URL=postgres://user:pass@localhost:5432/dealflow_dev   # app DB (Drizzle reads this)
# DATABASE_URL_UNPOOLED=                                         # optional non-pooled URL for drizzle-kit migrations if a pooler is used
# TEST_DATABASE_URL=postgres://user:pass@localhost:5432/dealflow_test
#   Distinct from DATABASE_URL — used by apps/api/test/health.e2e-spec.ts (T-4 integration).
#   Must NEVER equal DATABASE_URL (architecture R-17 invariant; the test suite asserts this).
#   In CI this is set automatically by the postgres:18 service container in .github/workflows/ci.yml.
#   Leave unset locally to skip the integration suite; set to a local test DB to run it.

# ── Auth — SuperTokens, self-hosted on Railway, OWN Postgres instance (architecture/security.md) ──
SUPERTOKENS_CONNECTION_URI=     # SuperTokens Core URL (Railway private networking)
SUPERTOKENS_API_KEY=            # SuperTokens Core API key (Railway-generated)
SUPERTOKENS_DATABASE_URL=       # SuperTokens Core's SEPARATE Postgres (must NOT alias DATABASE_URL)
SESSION_SECRET=                 # app session signing secret — openssl rand -base64 32

# ── Audit log integrity (architecture/security.md) ──
AUDIT_LOG_HMAC_KEY=             # HMAC-SHA256 key for tamper-evident audit hash-chain — openssl rand -base64 32
AUDIT_LOG_HMAC_KEY_VERSION=1    # key version for rotation (chain_version)

# ── Data-source connection credential encryption (M7 admin, wave-15) ──
CREDENTIALS_ENC_KEY=           # AES-256-GCM key for data_source_connections.encrypted_credentials at rest — openssl rand -base64 32. Prod-only (set on the dealflow-api service); key-id prefix supports rotation. Fail-closed if unset.

# ── Transactional email + event tracking — pluggable provider (Resend candidate) (architecture/sdks.md) ──
EMAIL_PROVIDER_API_KEY=         # transactional email provider API key
EMAIL_WEBHOOK_SECRET=           # provider-agnostic webhook signing secret (opens/clicks/replies/bounces)
EMAIL_FROM_ADDRESS=             # verified sending identity (DKIM/SPF/DMARC configured on the domain)

# ── LLM provider — Anthropic / Claude (architecture/sdks.md) ──
ANTHROPIC_API_KEY=              # buyer-seller match rationale + AI-assisted outreach drafting (latest Claude models)

# ── Deal-source data + contact enrichment — pluggable providers (architecture/sdks.md) ──
# One key per connected provider, referenced by stable provider_key (creds in env, never in DB).
DATA_SOURCE_PRIMARY_API_KEY=    # primary deal-source data provider
ENRICHMENT_PROVIDER_API_KEY=    # contact-enrichment provider
AFFINITY_API_KEY=               # Affinity CRM API key (wave-30 M9). Generate in Affinity Settings → Manage Apps. Set on dealflow-api Railway service. Adapter returns [] gracefully if unset.

# ── Object storage — Railway Buckets (S3-compatible) (architecture/sdks.md) ──
S3_ENDPOINT=                    # Railway Buckets endpoint
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=                      # documents + recordkeeping export packages

# ── Background jobs — BullMQ on Redis (architecture/services.md, devops.md) ──
REDIS_URL=                      # Redis for BullMQ queues (sourcing, enrichment, outreach send, webhook, audit-integrity, export)

# ── Internal service wiring (architecture/services.md) ──
# Cross-origin session fix: apps/web proxies the same-origin path `/auth/*` to
# the api (apps/web/next.config.ts rewrites), so the browser reaches the API
# first-party and SuperTokens sets a first-party session cookie on the WEB
# origin. Env wiring for that model:
INTERNAL_API_BASE_URL=http://localhost:3001   # web → api base URL. USED BY THE WEB SERVICE: (1) next.config.ts rewrite target for /auth/* and (2) the dashboard server component's /auth/me fetch. Railway prod: the api's URL (private network preferred). MUST be set on the dealflow-web service.
NEXT_PUBLIC_API_URL=http://localhost:3001     # browser-visible API base for non-auth server fetches (home /health). Auth calls no longer use this (they go same-origin via the proxy). Keep = public api URL.
WEB_ORIGIN=http://localhost:3000              # Next.js public origin. USED BY THE API SERVICE for BOTH SuperTokens appInfo.apiDomain AND appInfo.websiteDomain (same-origin proxy model) + CORS allow-origin. Railway prod: the dealflow-web public URL exactly (e.g. https://dealflow-web-production-a4f7.up.railway.app). MUST be set on the dealflow-api service.

# ── Observability (architecture/devops.md) ──
# SENTRY_DSN=                   # add when production error tracking is enabled (not in MVP baseline)
