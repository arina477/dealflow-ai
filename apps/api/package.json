{
  "name": "@dealflow/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "build": "nest build",
    "start": "node dist/main.js",
    "lint": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check:worm-migration-tests": "tsx scripts/check-worm-migration-tests.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@anatine/zod-nestjs": "2.0.12",
    "@dealflow/shared": "workspace:*",
    "@nestjs/common": "11.1.27",
    "@nestjs/core": "11.1.27",
    "@nestjs/platform-express": "11.1.27",
    "drizzle-orm": "0.45.2",
    "pg": "8.22.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "supertokens-node": "24.0.2",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.23",
    "@nestjs/testing": "11.1.27",
    "@swc/core": "^1.15.43",
    "@types/express": "5.0.0",
    "@types/node": "26.1.0",
    "@types/pg": "8.20.0",
    "@types/supertest": "7.2.0",
    "drizzle-kit": "0.31.10",
    "supertest": "7.2.2",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "3.2.6"
  }
}
